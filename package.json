{
  "name": "accountibilitymax-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "seed:prepare": "node scripts/prepare-project-database-seed.mjs --hardlink",
    "seed:export-vectors": "node scripts/export-entity-vectors.mjs",
    "docker:up": "docker compose --env-file .env.docker up --build",
    "docker:down": "docker compose --env-file .env.docker down",
    "docker:reset-db": "docker compose --env-file .env.docker down -v && docker compose --env-file .env.docker up --build postgres"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "@tanstack/react-query": "^5.99.2",
    "@xyflow/react": "^12.10.2",
    "basecoat-css": "^0.3.11",
    "lucide-react": "^1.11.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "rss-parser": "^3.13.0",
    "tailwindcss": "^4.2.4"
  }
}
