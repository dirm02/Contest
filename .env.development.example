# Optional: copy to `.env.development` if you run the Vite UI directly.
# The API targets should be services that already use the GCP Cloud SQL database.

# Dossier API target. The default points at the local Docker dossier API, which
# connects to Cloud SQL through the compose `cloud-sql-proxy` service.
DEV_API_PROXY_TARGET=http://127.0.0.1:3801

# Ship analyst target. The default points at the local Docker ship API, which
# connects to the same GCP database.
SHIP_API_BASE_URL=http://localhost:8765
VITE_SHIP_API_BASE_URL=http://localhost:8765

# After Cloud Run is deployed, these can be changed to the printed Cloud Run API URLs
# if you want Vite dev to call the deployed backends directly.
