# Optional: copy to `.env.development` if you need overrides.
# Local dev uses fixed ports: web 5173, API proxy target below (run API separately on 3801).

# Dossier API (run from agency-26-hackathon/general: `npm run entities:dossier`)
DEV_API_PROXY_TARGET=http://127.0.0.1:3801

# Ship analyst backend (run from hackathon2026: `uv run uvicorn output.ship.server:app --port 8765`)
SHIP_API_BASE_URL=http://localhost:8765
VITE_SHIP_API_BASE_URL=http://localhost:8765
