# Copy to deploy/gcp/env and edit before running the GCP scripts.
# Keep deploy/gcp/env out of git.

# Cloud Run, Cloud SQL, Artifact Registry, and Secret Manager live here.
PROJECT_ID=agency2026ot-doge-v-0429
REGION=northamerica-northeast1
ARTIFACT_REPOSITORY=maple-doge

CLOUD_SQL_INSTANCE=maple-doge-postgres
CLOUD_SQL_CONNECTION_NAME=agency2026ot-doge-v-0429:northamerica-northeast1:maple-doge-postgres
CLOUD_SQL_DATABASE=hackathon
CLOUD_SQL_USER=hackathon
CLOUD_SQL_TIER=db-custom-4-16384
CLOUD_SQL_STORAGE_GB=250
CLOUD_SQL_LOCAL_PORT=55433

DB_PASSWORD_SECRET=maple-doge-db-password
OPENAI_API_KEY_SECRET=maple-doge-openai-api-key
CANLII_API_KEY_SECRET=maple-doge-canlii-api-key

WEB_SERVICE=maple-doge-web
DOSSIER_API_SERVICE=maple-doge-dossier-api
SHIP_API_SERVICE=maple-doge-ship-api

WEB_IMAGE=maple-doge-web
DOSSIER_API_IMAGE=maple-doge-dossier-api
SHIP_API_IMAGE=maple-doge-ship-api

SEED_DUMP_PATH=services/postgres/seed/hackathon.dump
VECTOR_EXPORT_PATH=services/postgres/seed/entity-vectors

PRIMARY_MODEL=gpt-5.5
FAST_MODEL=gpt-5.5
WEB_SEARCH_ENABLED=true

# Source-data BigQuery stays in the data project. Do not point this at the app project.
GOOGLE_CLOUD_PROJECT=agency2026ot-data-1776775157
BIGQUERY_DATASET=agency_hackathon_data
BIGQUERY_LOCATION=northamerica-northeast1
BIGQUERY_TABLE_LAYOUT=split
