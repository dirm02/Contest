# Copy values into GCP Secret Manager or a local, gitignored `.env.docker`.
# Do not commit real secret values.

OPENAI_API_KEY=
WEB_SEARCH_ENABLED=true
CANLII_API_KEY=

# App runtime project: Cloud Run, Cloud SQL, Artifact Registry, and Secret Manager.
PROJECT_ID=agency2026ot-doge-v-0429
REGION=northamerica-northeast1
CLOUD_SQL_INSTANCE=maple-doge-postgres
CLOUD_SQL_CONNECTION_NAME=agency2026ot-doge-v-0429:northamerica-northeast1:maple-doge-postgres
CLOUD_SQL_DATABASE=hackathon
CLOUD_SQL_USER=hackathon
CLOUD_SQL_LOCAL_PORT=55433
DB_USER=hackathon
DB_PASSWORD=
DB_NAME=hackathon
DB_HOST=cloud-sql-proxy
DB_PORT=5432
LOCAL_GCLOUD_CONFIG_DIR=/home/david/.config/gcloud

# Local-postgres fallback only. The default local Docker stack uses Cloud SQL.
POSTGRES_DB=hackathon
POSTGRES_USER=hackathon
POSTGRES_PASSWORD=change-me

PRIMARY_MODEL=gpt-5.5
FAST_MODEL=gpt-5.5

# Source-data BigQuery stays in the data project.
GOOGLE_CLOUD_PROJECT=agency2026ot-data-1776775157
BIGQUERY_DATASET=agency_hackathon_data
BIGQUERY_LOCATION=northamerica-northeast1
BIGQUERY_TABLE_LAYOUT=split
