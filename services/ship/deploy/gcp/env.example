# Copy to `services/ship/deploy/gcp/env` and edit before running scripts.
# Do not put real secret values in this file.

PROJECT_ID=your-gcp-project-id
REGION=us-central1
ZONE=us-central1-a

REPOSITORY=ship
SERVICE_NAME=ship-service
RUNTIME_SA=ship-service

INSTANCE=ship-postgres
DB_NAME=hackathon
DB_USER=hackathon
DB_TIER=db-custom-2-7680
DB_STORAGE_SIZE=50GB
DB_AVAILABILITY=zonal
DB_PASSWORD_SECRET=ship-db-password

OPENAI_SECRET_NAME=openai-api-key
CANLII_SECRET_NAME=canlii-api-key

BUCKET=your-gcp-project-id-ship-data
DUMP_PATH=/absolute/path/to/hackathon.dump
DUMP_FORMAT=auto

MEMORY=2Gi
CPU=2
CONCURRENCY=8
TIMEOUT=300s
MIN_INSTANCES=0
MAX_INSTANCES=10
ALLOW_UNAUTHENTICATED=true
ENABLE_HTTP2=false

