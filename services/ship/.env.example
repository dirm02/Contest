# Copy this file to `services/ship/.env` for local Docker Compose.
# Do not commit real secret values.

# Local Docker Compose points the service at the `ship-db` container.
DATABASE_URL=postgresql://hackathon:hackathon@ship-db:5432/hackathon

# Required before asking analytical questions.
OPENAI_API_KEY=

# Optional, improves adverse-media court-record lookup and URL verification.
CANLII_API_KEY=

# Ship service model defaults copied from the source service contract.
PRIMARY_MODEL=gpt-5.5
FAST_MODEL=gpt-5.5

# Local API port. Cloud Run provides PORT=8080.
SHIP_API_PORT=8765
SHIP_PROMPT_CACHE_RETENTION=24h

