# general/.env.example — template only. Copy this to `.env.public` (shared
# defaults) or `.env` (personal admin overrides) and fill in real values.
# Both files are gitignored. See SECURITY.md at the repo root for loading
# order and credential conventions.
#
# Hackathon participants (AI For Accountability, 2026-04-29):
# You do NOT fill this file in yourself. The hackathon organizers provide
# pre-populated `.env.public` files (one per module: CRA/, FED/, AB/,
# general/) in the info pack distributed on event day — drop them into
# place and the pipeline connects automatically. This example exists so
# you can see the shape of the config and, if needed, add your own `.env`
# with personal admin overrides or a local-Postgres connection string.

# ─── Required: PostgreSQL connection ────────────────────────────────────
# For participants, this is the shared read-only user distributed out-of-band.
# For pipeline operators (running migrations + the full pipeline), this is
# an admin user with CREATE + INSERT + UPDATE privileges.
DB_CONNECTION_STRING=postgresql://username:password@host:5432/database?sslmode=require

# Pool size for parallel work (LLM phase benefits from larger pools).
DB_POOL_MAX=25

# ─── Optional: LLM providers for Stage 6 (08-llm-golden-records.js) ─────
# Set either one, or both (both enables dual-provider parallel throughput —
# the `08a` and `08b` dashboard buttons fire Anthropic and Vertex at the
# same time against different candidate subsets).

# Anthropic direct API
ANTHROPIC_API_KEY=sk-ant-...

# Google Vertex AI (Claude on Google Cloud)
VERTEX_PROJECT_ID=your-google-cloud-project
VERTEX_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","token_uri":"https://oauth2.googleapis.com/token"}
VERTEX_CLAUDE_SONNET_MODEL=claude-sonnet-4-6
VERTEX_LOCATION_ID=global

# ─── Optional: Splink reference sample (for compare:splink quality tool) ─
# Download splink-master-table from the Splink team's release and point this
# at the extracted folder. If unset, the tool tries `../splink-master-table/`.
# SPLINK_MASTER_DIR=C:\path\to\splink-master-table

# ─── Optional: Dashboard overrides ──────────────────────────────────────
# PORT=3800                      # dashboard port (default 3800)
# DASHBOARD_POLL_MS=2000         # DB-poll frequency (default 2000ms)
# DASHBOARD_DEBUG=1              # log slow-query warnings to console
